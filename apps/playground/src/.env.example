# Machine API: omit VITE_MACHINE_BASE_URL in the browser — the app uses the page origin
# so /api/v1/chat/completions is proxied to apps/web (see vite.config.ts). Never set
# VITE_MACHINE_BASE_URL or VITE_WORKOS_TOKEN_ENDPOINT to https://…authkit.app (CORS).
# Optional: fixed origin if you are not using the dev server origin.
# VITE_MACHINE_BASE_URL=http://localhost:5173

VITE_MACHINE_ACCESS_TOKEN=
VITE_MACHINE_REFRESH_TOKEN=
VITE_MACHINE_CLIENT_ID=
VITE_MACHINE_CLIENT_SECRET=
